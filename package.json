{
	"name": "@moleculer/mcp-server",
	"version": "0.2.0",
	"description": "Moleculer MCP Server",
	"type": "module",
	"main": "./dist/cjs/index.js",
	"module": "./dist/esm/index.js",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"require": "./dist/cjs/index.js",
			"import": "./dist/esm/index.js",
			"default": "./src/index.ts"
		}
	},
	"files": [
		"README.md",
		"LICENSE",
		"dist"
	],
	"scripts": {
		"dev": "set DANGEROUSLY_OMIT_AUTH=true && nodemon --inspect examples/index.ts",
		"start": "tsx src/index.ts",
		"inspect": "set DANGEROUSLY_OMIT_AUTH=true && npx @modelcontextprotocol/inspector tsx ./src/index.ts",
		"client": "tsx examples/client/index.ts",
		"ci": "vitest --watch",
		"test": "vitest --run --coverage",
		"deps": "ncu -i && npm audit fix",
		"ci-update-deps": "ncu -u",
		"lint": "eslint --ext=.ts src examples test",
		"lint:fix": "eslint --ext=.ts src examples test --fix",
		"check": "tsc --noEmit true",
		"prebuild": "rimraf dist",
		"build": "NODE_OPTIONS='--max-old-space-size=4096' tsc -b tsconfig.cjs.json tsconfig.esm.json tsconfig.types.json",
		"postbuild": "echo {\"type\": \"commonjs\"} > dist/cjs/package.json && echo {\"type\": \"module\"} > dist/esm/package.json",
		"prepack": "npm run build"
	},
	"keywords": [
		"mcp-server",
		"moleculer",
		"microservice"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/moleculerjs/mcp-server.git"
	},
	"author": "MoleculerJS",
	"license": "MIT",
	"peerDependencies": {
		"moleculer": "^0.15.0"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.28.0",
		"lodash": "^4.17.23",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@modelcontextprotocol/inspector": "^0.21.1",
		"@moleculer/database": "^0.4.0",
		"@seald-io/nedb": "^4.1.2",
		"@types/lodash": "^4.17.24",
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^4.1.2",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-node": "^11.1.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-promise": "^7.2.1",
		"eslint-plugin-security": "^4.0.0",
		"globals": "^17.4.0",
		"moleculer": "^0.15.0",
		"moleculer-repl": "^0.7.4",
		"moleculer-web": "^0.11.0",
		"nodemon": "^3.1.14",
		"npm-check-updates": "^19.6.6",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.57.2",
		"vitest": "^4.1.2"
	},
	"engines": {
		"node": ">= 20.x.x"
	}
}
